{
  "buildCommand": "pnpm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "redirects": [
    {
      "source": "/cyber-status-check",
      "destination": "/check",
      "permanent": true
    },
    {
      "source": "/cyber-status-check-b",
      "destination": "/check",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/firewallflat",
      "destination": "/firewallflat/index.html"
    },
    {
      "source": "/firewallflat/(.*)",
      "destination": "/firewallflat/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
