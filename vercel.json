{
  "buildCommand": "pnpm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/cyber-status-check", "destination": "/cyber-status-check/index.html" },
    { "source": "/cyber-status-check/(.*)", "destination": "/cyber-status-check/$1" },
    { "source": "/firewallflat", "destination": "/firewallflat/index.html" },
    { "source": "/firewallflat/(.*)", "destination": "/firewallflat/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
